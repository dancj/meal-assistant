# Demo mode — set to 1 to render the UI with built-in fixture data
# without calling GitHub, Flipp, or Anthropic. Useful for local dev and
# screenshots. Leave unset for normal operation.
# DEMO_MODE=1

# GitHub recipe store (#64, #68, #69) — required for /api/recipes,
# /api/log, and /api/pantry (ignored when DEMO_MODE=1).
# PAT scope: Contents: Read AND Write (write is required for /api/log;
# /api/recipes and /api/pantry are read-only).
GITHUB_PAT=your-github-pat
RECIPES_REPO=your-username/your-recipes
RECIPES_PATH=recipes

# Deals (#65) — optional; both default to 34238 when unset
SAFEWAY_ZIP=34238
ALDI_ZIP=34238

# Meal plan generator (#66) — required for /api/generate-plan
# Get a key at https://console.anthropic.com (paid; no free tier)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email delivery (#70) — all optional. RESEND_API_KEY is the gate: when
# set, the page renders an "Email me this" button that POSTs the
# in-memory plan to /api/email and Resend delivers it. When unset, the
# button is hidden and the rest of the app works unchanged.
# EMAIL_FROM and EMAIL_RECIPIENTS are required ONLY when RESEND_API_KEY
# is set; otherwise the click returns 500. EMAIL_RECIPIENTS is a
# comma-separated list. Note: the Resend free tier (onboarding@resend.dev)
# only delivers to the account-owner inbox — use a verified custom
# domain in EMAIL_FROM to deliver to other recipients.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=onboarding@resend.dev
EMAIL_RECIPIENTS=you@example.com
